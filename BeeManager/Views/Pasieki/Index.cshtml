@model IEnumerable<BeeManager.Models.Pasieka>

@{
    ViewData["Title"] = "Pasieki";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="mb-0">Pasieki</h1>
        <div class="text-muted">Lista pasiek w systemie.</div>
    </div>
    <a class="btn btn-primary" asp-action="Create">+ Dodaj pasiekę</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nazwa</th>
                        <th>Lokalizacja</th>
                        <th>Opis</th>
                        <th style="width: 220px;" class="text-end">Akcje</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Nazwa</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Lokalizacja) ? "-" : item.Lokalizacja)</td>
                            <td class="text-muted">
                                @(
                                                            string.IsNullOrWhiteSpace(item.Opis)
                                                            ? "-"
                                                            : (item.Opis.Length > 60 ? item.Opis.Substring(0, 60) + "..." : item.Opis)
                                                            )
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Edytuj</a>
                            <a class="btn btn-sm btn-outline-info" asp-action="Details" asp-route-id="@item.Id">Szczegóły</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Usuń</a>
                        </td>
                    </tr>
                                        }
                </tbody>
            </table>
        </div>
    </div>
</div>
