@model BeeManager.Models.Miodobranie

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Miodobranie</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="UlId" class="control-label"></label>
                <select asp-for="UlId" class="form-control" asp-items="ViewBag.UlId"></select>
                <span asp-validation-for="UlId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DataMiodobrania" class="control-label"></label>
                <input asp-for="DataMiodobrania" class="form-control" type="date" />
                <span asp-validation-for="DataMiodobrania" class="text-danger"></span>
            </div>

            <select asp-for="TypMiodu" class="form-control"
                    asp-items="Html.GetEnumSelectList<BeeManager.Models.TypMioduEnum>()">
            </select>
            <span asp-validation-for="TypMiodu" class="text-danger"></span>

            <div class="form-group">
                <label asp-for="IloscKg" class="control-label"></label>
                <input asp-for="IloscKg" class="form-control" />
                <span asp-validation-for="IloscKg" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Notatki" class="control-label"></label>
                <input asp-for="Notatki" class="form-control" />
                <span asp-validation-for="Notatki" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
